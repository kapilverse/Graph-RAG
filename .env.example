# ============================================================================
# Graph RAG — environment configuration
# Copy this file to ".env" and fill in the values you need.
# All settings have safe defaults; only LLM keys are required for AI features.
# ============================================================================

# ---------------------------------------------------------------------------
# LLM — providers are tried in order; first one configured wins.
# The system is OpenAI-compatible, so any provider exposing /v1 works.
# ---------------------------------------------------------------------------
# Primary: Google Gemini 2.0 Flash (free tier, 1,500 req/day)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# Fallback: Hugging Face Inference API (free, open models)
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Extraction / generation tuning ---
EXTRACTION_TEMPERATURE=0.0
GENERATION_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Embeddings & reranker (local sentence-transformers, downloaded on first run)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Set to 1 to force CPU (slower but no GPU needed). 0 = use CUDA if available.
FORCE_CPU=1

# ---------------------------------------------------------------------------
# Neo4j (graph DB) — runs in docker-compose
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Qdrant (vector DB) — runs in docker-compose
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_CHUNKS=graphrag_chunks
QDRANT_COLLECTION_COMMUNITIES=graphrag_communities

# ---------------------------------------------------------------------------
# Chunking
# ---------------------------------------------------------------------------
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64      # ~12.5% overlap (spec: 10-15%)

# ---------------------------------------------------------------------------
# Retrieval
# ---------------------------------------------------------------------------
LOCAL_TRAVERSAL_DEPTH=2      # hops for local search
LOCAL_NEIGHBOR_LIMIT=20
RERANK_TOP_K=10
COMMUNITY_TOP_K=5
